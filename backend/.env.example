# Copy this file to .env and fill in your real MySQL credentials.
# .env is git-ignored, never commit real credentials.

DB_HOST=your-mysql-host-or-ip
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_username
DB_PASSWORD=your_password

# JSON array of allowed frontend origins
CORS_ORIGINS=["http://localhost:3000"]

# Secret used to sign JWT login tokens, set to a long random string
JWT_SECRET_KEY=JWT_secret_string
RESEND_API_KEY=RESEND_secret_string