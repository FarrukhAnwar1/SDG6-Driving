# Copy this file to .env and fill in your real MySQL credentials.
# .env is git-ignored, never commit real credentials.

DB_HOST=your-mysql-host-or-ip
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_username
DB_PASSWORD=your_password

# JSON array of allowed frontend origins
CORS_ORIGINS=["http://localhost:3000"]

# Email verification and Resend email config
JWT_SECRET_KEY=your-random-secret-key
JWT_ALGORITHM=HS256
VERIFICATION_TOKEN_EXPIRE_HOURS=24
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=onboarding@resend.dev       # sandbox address until a domain is verified
API_BASE_URL=http://localhost:8000
